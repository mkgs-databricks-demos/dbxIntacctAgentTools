# Pin the public npm registry so package-lock.json never picks up a
# resolution from npm-proxy.dev.databricks.com (the internal Databricks
# proxy that GitHub Actions runners can't reach). Without this, anyone
# running `npm install` on the Databricks corp network rewrites the
# lockfile with internal-proxy URLs and CI's `npm ci` hangs for 8
# minutes before failing.
registry=https://registry.npmjs.org/
